# 伺服器端（API Route）優先讀這個；Vercel 建議設定此值
R2_BASE_URL=https://pub-f5f2f36165ac42769dac0b998795600d.r2.dev
# 前端（若需直連）可讀這個；可與 R2_BASE_URL 設同值
NEXT_PUBLIC_R2_BASE_URL=https://pub-f5f2f36165ac42769dac0b998795600d.r2.dev
# 僅當「實際 fetch 的 URL」必須多一段前綴時才設（勿加頭尾 /）。Cloudflare pub-*.r2.dev 一般物件鍵為 v1/...，與主控台桶名不同，多數專案應留空。
# R2_ASSET_PREFIX=
# 本機開發：設為 true 則使用 public/ 靜態檔，不會打 R2
NEXT_PUBLIC_USE_LOCAL_ASSETS=true
# 建議維持 true：由 Next 代理 R2，避免 WebGL 跨網域載入問題
NEXT_PUBLIC_R2_USE_PROXY=true
# 每次更新 R2 的 main-bg.png 請遞增，避免仍顯示舊圖
NEXT_PUBLIC_MAIN_BG_VERSION=1
# Google Analytics 4 測量 ID（格式：G-XXXXXXXXXX）
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-E821ZWSB4Y
